const displayEl = document.getElementById('password-display');
const copyBtn = document.getElementById('copy-btn');
const lengthEl = document.getElementById('length');
const lengthVal = document.getElementById('length-val');
const uppercaseEl = document.getElementById('uppercase');
const lowercaseEl = document.getElementById('lowercase');
const numbersEl = document.getElementById('numbers');
const symbolsEl = document.getElementById('symbols');
const generateBtn = document.getElementById('generate-btn');
const strengthMeter = document.getElementById('strength-meter');
const strengthBar = document.getElementById('strength-bar');
const strengthText = document.getElementById('strength-text');

// Atualiza o texto do tamanho da senha na tela
lengthEl.addEventListener('input', (e) => {
    lengthVal.innerText = e.target.value;
});

// Grupos de caracteres
const chars = {
    uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
    lowercase: 'abcdefghijklmnopqrstuvwxyz',
    numbers: '0123456789',
    symbols: '!@#$%^&*()_+~`|}{[]:;?><,./-='
};

// Função de segurança usando Web Crypto API
function getRandomSecureByte() {
    const array = new Uint32Array(1);
    window.crypto.getRandomValues(array);
    return array[0];
}

function generatePassword() {
    let characterPool = '';
    let password = '';

    if (uppercaseEl.checked) characterPool += chars.uppercase;
    if (lowercaseEl.checked) characterPool += chars.lowercase;
    if (numbersEl.checked) characterPool += chars.numbers;
    if (symbolsEl.checked) characterPool += chars.symbols;

    const length = parseInt(lengthEl.value);

    if (characterPool.length === 0) {
        alert('Por favor, selecione pelo menos uma opção de caracteres!');
        return '';
    }

    // Monta a senha usando sorteio criptograficamente seguro
    for (let i = 0; i < length; i++) {
        const randomIndex = getRandomSecureByte() % characterPool.length;
        password += characterPool[randomIndex];
    }

    return password;
}

// Medidor de força simples baseado no tamanho e tipos
function updateStrength(password) {
    if (!password) {
        strengthMeter.style.display = 'none';
        return;
    }
    
    strengthMeter.style.display = 'flex';
    const length = password.length;
    let score = 0;

    if (length >= 12) score++;
    if (length >= 16) score++;
    if (/[A-Z]/.test(password) && /[a-z]/.test(password)) score++;
    if (/[0-9]/.test(password)) score++;
    if (/[^A-Za-z0-9]/.test(password)) score++;

    if (score <= 2) {
        strengthBar.style.backgroundColor = '#ef4444'; // Vermelho
        strengthText.innerText = 'Força: Fraca (Insegura)';
    } else if (score === 3 || score === 4) {
        strengthBar.style.backgroundColor = '#eab308'; // Amarelo
        strengthText.innerText = 'Força: Média';
    } else {
        strengthBar.style.backgroundColor = '#22c55e'; // Verde
        strengthText.innerText = 'Força: Muito Forte';
    }
}

// Evento do botão gerar
generateBtn.addEventListener('click', () => {
    const pwd = generatePassword();
    displayEl.value = pwd;
    updateStrength(pwd);
    copyBtn.innerText = 'Copiar';
});

// Evento de copiar para a área de transferência
copyBtn.addEventListener('click', async () => {
    const pwd = displayEl.value;
    if (!pwd) return;

    try {
        await navigator.clipboard.writeText(pwd);
        copyBtn.innerText = 'Copiado!';
        setTimeout(() => copyBtn.innerText = 'Copiar', 2000);
    } catch (err) {
        alert('Falha ao copiar a senha.');
    }
});
